#!/usr/bin/env sh
# shellcheck disable=SC1090,SC1091,SC2155

set -o errexit

SYSTEM_HOSTNAME="$(uname -n | sed 's|.local||g')"
HOMEBREW_INSTALL_SCRIPT="https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh"
ANSIBLE_REPO_PATH="${HOME}/dotfiles"
ANSIBLE_REPO_BRANCH="main"
ANSIBLE_REPO_HOSTVARS_DIR="${ANSIBLE_REPO_PATH}/host_vars"
ANSIBLE_REPO_URL="https://github.com/bradleyfrank/ansible.git"


usage() {
  echo "install: system and Ansible bootstrap script"
  echo
  echo "USAGE: sh install [OPTIONS]"
  echo
  echo "OPTIONS:"
  echo "  -h          Show help and exit"
  echo "  -b <branch> Name of git branch to use"
  echo "  -p          Resume a failed Ansible run"
  echo "  -r          Start a bootstrap from scratch"
  echo "  -u <url>    URL of Ansible repo to use"
  echo "  -w          Skip Homebrew install on Linux (noop for macOS)"
  echo
}


install_homebrew() {
  case "$ID" in
    fedora) sudo dnf install -y procps-ng file @development-tools python3-libdnf5 ;;
    debian|ubuntu|linuxmint) sudo apt-get install -y build-essential procps file ;;
    macos) sudo softwareupdate --install-rosetta ;;
  esac
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL $HOMEBREW_INSTALL_SCRIPT)"
}


bootstrap_mac() {
  pgrep caffeinate >/dev/null || (caffeinate -d -i -m -u &)
  sudo scutil --set HostName "$SYSTEM_HOSTNAME"
  export PATH="/opt/homebrew/bin:/usr/local/bin:${PATH}"
  ID=macos install_homebrew
  brew install python3 git
}


bootstrap_linux() {
  pgrep systemd-inhibit >/dev/null || (sudo systemd-inhibit sleep infinity &)
  sudo hostnamectl set-hostname "$SYSTEM_HOSTNAME"
  sudo systemctl stop packagekit
  . /etc/os-release

  case "$ID" in
    fedora)
      sudo dnf clean all
      sudo dnf makecache
      sudo dnf install -y python3 python3-devel python3-pip python3-wheel gcc git
      ;;
    debian|ubuntu|linuxmint)
      sudo apt-get clean
      sudo apt-get update
      sudo apt-get install -y python3 python3-pip python3-venv git lsb-release
      ;;
    *) exit 1 ;;
  esac

  case $(uname -m) in (aarch*|arm*)
    SKIP_HOMEBREW_LINUX=1 ;;  # https://github.com/Homebrew/brew/issues/19208
  esac

  if [ -z "$SKIP_HOMEBREW_LINUX" ]; then
    install_homebrew
  fi
}


reset_install() {
  rm -rf "$ANSIBLE_REPO_PATH" "${HOME}/.ssh"

  export PATH="/opt/homebrew/bin:/home/linuxbrew/.linuxbrew/bin:${PATH}"

  [ -x op ] || return 0
  op account get >/dev/null 2>&1 || eval "$(op signin)"

  op_item_list="$(mktemp)"

  op item list --categories SERVER \
    | grep "$(uname -n)" \
    | awk '{print $1}' > "$op_item_list"

  while read -r item_id; do
    op item delete "$item_id" --archive
  done < "$op_item_list"
}


while getopts "hb:pru:w" opt; do
  case "$opt" in
    b) ANSIBLE_REPO_BRANCH="$OPTARG" ;;
    h) usage; exit 0 ;;
    p) SKIP_BOOTSTRAP=true ;;
    r) reset_install ;;
    u) ANSIBLE_REPO_URL="$OPTARG" ;;
    w) SKIP_HOMEBREW_LINUX=true ;;
    *) usage; exit 1 ;;
  esac
done


if [ -z "$SKIP_BOOTSTRAP" ]; then
  printf "Enter hostname [%s]: " "$SYSTEM_HOSTNAME"
  read -r SYSTEM_HOSTNAME

  case $(uname -s) in
    Darwin) bootstrap_mac ;;
    Linux)  bootstrap_linux ;;
    *)      exit 1 ;;
  esac
fi


export PATH="$(python3 -m site --user-base)/bin:${PATH}"
export ANSIBLE_PYTHON_INTERPRETER="venv/bin/python3"
export ANSIBLE_HOME="${HOME}/.config/ansible"


if [ -d "$ANSIBLE_REPO_PATH" ]; then
  cd "$ANSIBLE_REPO_PATH"
  git pull
else
  git clone "$ANSIBLE_REPO_URL" "$ANSIBLE_REPO_PATH"
  cd "$ANSIBLE_REPO_PATH"
  git checkout "$ANSIBLE_REPO_BRANCH"
  python3 -m venv venv --system-site-packages  # required for selinux libs on Fedora
fi

. venv/bin/activate
pip install --no-cache-dir --requirement requirements.txt


ANSIBLE_REPO_HOSTVARS="${ANSIBLE_REPO_HOSTVARS_DIR}/${SYSTEM_HOSTNAME}.yml"

if [ ! -s "$ANSIBLE_REPO_HOSTVARS" ]; then
  ansible-playbook play_bootstrap_ansible.yml
  grep "^(#|-|$)" roles/*/defaults/main.yml \
    --invert-match \
    --no-filename \
    --extended-regexp \
    --color=never \
    | sed "s/^/# /g" >> "${ANSIBLE_REPO_HOSTVARS}"
  vi "$ANSIBLE_REPO_HOSTVARS"
fi


ansible-playbook play_init_onepassword.yml --ask-become-pass
. "${HOME}/.op_session"
rm -f "${HOME}/.op_session"


ansible-playbook play_all_roles.yml --ask-become-pass --tags "all,never"
